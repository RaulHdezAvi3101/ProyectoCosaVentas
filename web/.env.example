# Fase 3 — copiar a .env (no commitear .env)
DATABASE_URL="postgresql://cosaventas:cosaventas@localhost:5432/cosaventas"
REDIS_URL="redis://localhost:6379"

# Mínimo 32 caracteres en local
SESSION_SECRET="cosaventas-local-dev-change-this-secret"

# Permitir claim sin login (solo dev). En producción usar "false".
ALLOW_GUEST_CLAIM="true"

# Fallback a Map en memoria si no hay Redis/PG
USE_MEMORY_STORE="false"

# db | mock — por defecto usa PG si DATABASE_URL responde
DATA_SOURCE="db"

# Ventana de pago: 1800000 = 30 min; 60000 = 1 min (pruebas Entrega 4)
PAYMENT_WINDOW_MS="1800000"

NODE_ENV="development"
PORT="3000"

# Slugs del carrusel de destacados (CSV, orden = orden del carrusel)
# FEATURED_SLUGS="live-charizard,listing-2,listing-3"
