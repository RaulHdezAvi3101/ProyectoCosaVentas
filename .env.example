# mio — copiar a .env (no commitear .env)

# --- Fase 0+ ---
NODE_ENV=development
PORT=3000

DATABASE_URL=postgresql://mio:mio@localhost:5432/mio
REDIS_URL=redis://localhost:6379

# --- Fase 1+ ---
SESSION_SECRET=dev-change-me-use-openssl-rand-hex-32-in-production

# --- Fase 2+ ---
DATA_SOURCE=db

# --- Fase 0 demo ---
ENABLE_DEMO=true

# --- Fase 3 First-to-Claim ---
ALLOW_GUEST_CLAIM=true
PAYMENT_WINDOW_MS=1800000
# USE_MEMORY_STORE=true

