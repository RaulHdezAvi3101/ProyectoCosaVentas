{
  "name": "mio",
  "version": "1.0.0-beta",
  "private": true,
  "scripts": {
    "dev": "tsx server.ts",
    "build": "next build",
    "start": "NODE_ENV=production tsx server.ts",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "db:migrate": "prisma migrate dev",
    "db:seed": "prisma db seed",
    "db:dump": "pg_dump \"$DATABASE_URL\" --no-owner --no-acl -f prisma/dumps/mio-full.sql",
    "db:restore": "psql \"$DATABASE_URL\" -f prisma/dumps/mio-full.sql",
    "simulate:claim": "tsx scripts/simulate-claim.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1057.0",
    "@prisma/client": "^5.22.0",
    "bcrypt": "^6.0.0",
    "bullmq": "^5.34.8",
    "clsx": "^2.1.1",
    "exifr": "^7.1.3",
    "ioredis": "^5.4.2",
    "next": "^14.2.28",
    "piexifjs": "^1.0.6",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "socket.io": "^4.8.1",
    "socket.io-client": "^4.8.3",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/node": "^22.10.5",
    "@types/piexifjs": "^1.0.0",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.57.1",
    "eslint-config-next": "^14.2.28",
    "postcss": "^8.4.49",
    "prisma": "^5.22.0",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
